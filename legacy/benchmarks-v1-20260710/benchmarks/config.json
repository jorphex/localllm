{
  "meta": {
    "schema_version": "2026-06-20",
    "description": "Shared benchmark configuration for all localllm model-evaluation harnesses."
  },
  "server": {
    "np": 1,
    "tb": 8,
    "batch_size": 1024,
    "ub": 512,
    "flash_attention": true,
    "threads_http": 4,
    "cache_type_k": "q8_0",
    "cache_type_v": "q8_0",
    "reasoning": true,
    "metrics": true,
    "no_warmup": true,
    "no_mmap": true,
    "image_max_tokens": 12288,
    "ctx_checkpoints": null,
    "swa_full": false,
    "slot_save_path": "state/main-slots",
    "default_context": 262144,
    "default_sampling": {
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20,
      "min_p": 0.0,
      "presence_penalty": 0.0,
      "repeat_penalty": 1.0,
      "spec_default": true
    }
  },
  "agentic_sampling": {
    "temperature": 0.2,
    "top_p": 0.95,
    "top_k": 20,
    "repeat_penalty": 1.05,
    "presence_penalty": 0.0,
    "chat_template_kwargs": {
      "enable_thinking": true
    }
  },
  "suites": {
    "transcript_replay": {
      "family": "general_agentic",
      "fixtures": [
        "retry_triage_real",
        "retry_fix_real",
        "queue_fix_real",
        "retry_tool_followthrough",
        "soak_real"
      ]
    },
    "sim_compare": {
      "family": "coding_agentic",
      "scenarios": [
        "retry_bugfix",
        "retry_review_feedback",
        "queue_bugfix",
        "tool_error_recovery",
        "command_denial_recovery",
        "batch_tail_recovery",
        "flush_report_two_file_fix",
        "session_store_exploration"
      ]
    },
    "opencode_compare": {
      "family": "coding_agentic",
      "scenarios": [
        "repo_triage",
        "revise_after_feedback",
        "tool_followthrough"
      ]
    },
    "agentic_barrage": {
      "family": "general_agentic",
      "scenarios": [
        "plan_then_revise",
        "review_then_retry",
        "codex_workflow",
        "evidence_triage",
        "tool_restraint",
        "tool_followthrough"
      ]
    },
    "coding_compare": {
      "family": "coding_agentic",
      "prompts": [
        "simple_edit",
        "retry_bug",
        "task_runner",
        "merge_intervals"
      ]
    }
  },
  "scoring": {
    "sim_compare": {
      "weights": {
        "pass": 0.4,
        "scope_clean": 0.25,
        "tool_error_free": 0.2,
        "efficiency": 0.15
      },
      "efficiency_max_turns": 12
    }
  },
  "paths": {
    "summaries_dir": "benchmarks/summaries",
    "results_dir": "benchmarks/results"
  }
}
